model User {
    id           String       @id @default(uuid())
    name         String
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt
    profileId    Profile?

    @@map("users")
}
